# Postgres connection string (Neon, Supabase, or local Postgres).
# Leave unset to run in zero-setup mock mode (in-memory demo data).
DATABASE_URL="postgresql://user:password@localhost:5432/listing_agent"

# Direct (non-pooled) connection for Prisma migrations. Only needed when
# DATABASE_URL points at a pooled endpoint (e.g. Neon pooler, PgBouncer).
# DIRECT_URL="postgresql://user:password@localhost:5432/listing_agent"

# Protects /api/cron/refresh in production. Vercel Cron sends it as
# "Authorization: Bearer <secret>" automatically when set in the project.
CRON_SECRET=""

# Placeholder for a future real AI service behind lib/agent (mock today).
AI_GATEWAY_API_KEY=""

# eBay Sell APIs — leave empty until you have a developer account.
# https://developer.ebay.com/
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
EBAY_RU_NAME=""

# Etsy Open API v3 — leave empty until you have an app keystring.
# https://developers.etsy.com/
ETSY_KEYSTRING=""
ETSY_SHARED_SECRET=""

# Private photo storage (e.g. Vercel Blob read-write token).
BLOB_READ_WRITE_TOKEN=""
